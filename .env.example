# ══════════════════════════════════════════════════════════════
#  VitaGloss Social Hub — Variables de entorno
#  Copia este archivo a .env y completa los valores reales.
#  NUNCA commites el archivo .env al repositorio.
# ══════════════════════════════════════════════════════════════

# ── OpenAI ──────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Usa gpt-image-1 para imágenes (true) o DALL-E 3 URL (false)
USE_DALLE=true

# ── Meta / Facebook & Instagram ─────────────────────────────
META_APP_ID=123456789012345
META_APP_SECRET=abcdef12abcdef12abcdef12abcdef12
META_PAGE_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxx
META_PAGE_ID=123456789012345
META_INSTAGRAM_ACCOUNT_ID=123456789012345

# ── RunwayML (opcional — para generar Reels) ─────────────────
RUNWAYML_API_KEY=

# ── Base de datos ────────────────────────────────────────────
MONGO_URL=mongodb://mongo:27017
REDIS_URL=redis://redis:6379/0

# ── Autenticación JWT ────────────────────────────────────────
# IMPORTANTE: Cambia este valor por una cadena aleatoria larga y segura
JWT_SECRET_KEY=cambia-esta-clave-secreta-en-produccion-2026
JWT_EXPIRE_HOURS=24

# ── CORS (orígenes permitidos, separados por coma) ──────────
# En producción, pon la URL real de tu servidor (ej: https://tudominio.com)
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:3000

# ── Publisher Mode ───────────────────────────────────────────
PUBLISHER_MODE=real

# ── Misc ─────────────────────────────────────────────────────
PYTHONPATH=/app

# TELEGRAM_CHAT_ID=tu_telegram_chat_id
