# OpenAI API Configuration
OPENAI_API_KEY=tu_openai_api_key_aqui

# DALL-E 3 Configuration
# Nota: Requiere organización verificada en OpenAI
USE_DALLE=true

# Publisher Mode
# Valores: mock | real
PUBLISHER_MODE=mock

# Review Gate
REVIEW_GATE_ENABLED=false

# Security
APP_SECRET_KEY=genera-una-cadena-aleatoria-de-32-caracteres

# Database URLs (para Docker)
MONGO_URL=mongodb://mongo:27017
REDIS_URL=redis://redis:6379/0

# Social Media APIs (Requerido para publicación real)
# Obtener usando: python scripts/get_meta_tokens.py
FACEBOOK_PAGE_ID=tu_facebook_page_id
FACEBOOK_ACCESS_TOKEN=tu_facebook_page_access_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=tu_instagram_business_account_id
INSTAGRAM_ACCESS_TOKEN=tu_instagram_access_token

# Telegram Bot (Opcional - para notificaciones)
# TELEGRAM_BOT_TOKEN=tu_telegram_bot_token
# TELEGRAM_CHAT_ID=tu_telegram_chat_id
